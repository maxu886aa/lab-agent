{
  "version": 2,
  "buildCommand": "npx vite build",
  "outputDirectory": "dist/client",
  "functions": {
    "api/chat.js": {
      "runtime": "nodejs20.x"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
